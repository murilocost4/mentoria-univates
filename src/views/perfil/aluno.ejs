<% const title = 'Meu Perfil'; %>
<%- include('../partials/page-start', { title }) %>

<div class="page-header">
  <h1>Meu Perfil</h1>
  <p>Mantenha seus dados atualizados para uma melhor experiência.</p>
</div>

<div class="profile-layout">
  <aside class="profile-sidebar">
    <%- include('../partials/avatar', { name: user.name, photo: profile?.photo_url, size: 'lg' }) %>
    <h2><%= user.name %></h2>
    <p class="email"><%= user.email %></p>
    <span class="role-badge role-aluno" style="margin-top:0.75rem;display:inline-block">Aluno</span>

    <div class="profile-cta">
      <p class="text-secondary" style="font-size:0.85rem;margin-bottom:0.75rem">Quer compartilhar seu conhecimento?</p>
      <form method="POST" action="/virar-mentor">
        <button type="submit" class="btn btn-ghost btn-block">Quero ser mentor</button>
      </form>
    </div>
  </aside>

  <div class="panel">
    <h3 class="panel-title">Informações pessoais</h3>
    <form method="POST" action="/perfil" class="form">
      <div class="form-group">
        <label for="name">Nome completo *</label>
        <input type="text" id="name" name="name" value="<%= user.name %>" required>
      </div>
      <div class="form-group">
        <label for="photo_url">URL da foto</label>
        <input type="url" id="photo_url" name="photo_url" value="<%= profile?.photo_url || '' %>" placeholder="https://...">
        <p class="form-hint">Cole um link de imagem para exibir no seu perfil.</p>
      </div>
      <div class="form-group">
        <label for="course">Curso</label>
        <input type="text" id="course" name="course" value="<%= profile?.course || '' %>" placeholder="Ex: Engenharia de Software">
      </div>
      <div class="form-group">
        <label for="interests">Disciplinas de interesse</label>
        <input type="text" id="interests" name="interests" value="<%= (profile?.interests || []).join(', ') %>" placeholder="Algoritmos, Banco de Dados, POO">
        <p class="form-hint">Separe por vírgula.</p>
      </div>
      <button type="submit" class="btn btn-primary">Salvar alterações</button>
    </form>
  </div>
</div>

<%- include('../partials/page-end') %>
