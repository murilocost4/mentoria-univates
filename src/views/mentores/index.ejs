<% const title = 'Buscar Mentores'; %>
<%- include('../partials/page-start', { title }) %>

<div class="page-header">
  <h1>Encontre seu mentor</h1>
  <p>Explore mentores aprovados por disciplina, curso e disponibilidade.</p>
</div>

<form method="GET" action="/mentores" class="form filters">
  <div class="form-row">
    <div class="form-group">
      <label for="disciplina">Disciplina</label>
      <input type="text" id="disciplina" name="disciplina" value="<%= filters.disciplina %>" placeholder="Ex: Algoritmos">
    </div>
    <div class="form-group">
      <label for="curso">Curso</label>
      <input type="text" id="curso" name="curso" value="<%= filters.curso %>" placeholder="Ex: Ciência da Computação">
    </div>
    <div class="form-group">
      <label for="disponibilidade">Disponibilidade</label>
      <input type="text" id="disponibilidade" name="disponibilidade" value="<%= filters.disponibilidade %>" placeholder="Ex: segunda">
    </div>
    <button type="submit" class="btn btn-primary">Buscar</button>
  </div>
</form>

<% if (mentores.length === 0) { %>
  <div class="empty-state panel">
    <div class="empty-icon">🔍</div>
    <h3>Nenhum mentor encontrado</h3>
    <p>Tente ajustar os filtros ou volte mais tarde.</p>
  </div>
<% } else { %>
  <div class="cards">
    <% mentores.forEach(m => { %>
      <article class="card">
        <div class="card-header">
          <%- include('../partials/avatar', { name: m.name }) %>
          <div class="card-body">
            <h3><%= m.name %></h3>
            <p class="text-secondary" style="font-size:0.85rem"><%= m.course || 'Curso não informado' %></p>
          </div>
        </div>
        <% if (m.disciplines.length) { %>
          <div class="tags">
            <% m.disciplines.slice(0, 4).forEach(d => { %>
              <span class="tag"><%= d %></span>
            <% }) %>
            <% if (m.disciplines.length > 4) { %>
              <span class="tag tag-muted">+<%= m.disciplines.length - 4 %></span>
            <% } %>
          </div>
        <% } %>
        <div class="rating <%= m.review_count === 0 ? 'rating-muted' : '' %>">
          <% if (m.review_count > 0) { %>
            ★ <%= m.average_rating.toFixed(1) %> <span class="text-muted" style="font-weight:400">(<%= m.review_count %> avaliações)</span>
          <% } else { %>
            Sem avaliações ainda
          <% } %>
        </div>
        <div class="card-footer">
          <a href="/mentores/<%= m.user_id %>" class="btn btn-primary btn-block">Ver perfil e solicitar</a>
        </div>
      </article>
    <% }) %>
  </div>
<% } %>

<%- include('../partials/page-end') %>
