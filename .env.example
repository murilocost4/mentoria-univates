PORT=3000
SESSION_SECRET=altere-este-segredo-em-producao
SESSION_MAX_AGE_MS=86400000
BASE_URL=http://localhost:3000

# Turso (produção / Vercel) — obtenha em https://turso.tech
TURSO_DATABASE_URL=libsql://seu-banco-seu-usuario.turso.io
TURSO_AUTH_TOKEN=seu-token-aqui

# Sem TURSO_DATABASE_URL, usa SQLite local em database/app.db (desenvolvimento)

